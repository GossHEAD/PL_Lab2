digraph "waitUntilReady" {
  label="waitUntilReady";
  labelloc=t;
  node [shape=record, fontname="monospace", fontsize=9];
  edge [fontname="monospace", fontsize=8];

  bb0 [label="entry (BB0)\lx = read(sensor)\l", style=filled, fillcolor=lightgreen];
  bb1 [label="exit (BB1)", style=filled, fillcolor=lightyellow];
  bb2 [label="repeat.body (BB2)\lx = read(sensor)\l"];
  bb3 [label="repeat.cond (BB3)---\lcond: (x \> 0)\l"];
  bb4 [label="repeat.exit (BB4)\lx\l"];

  bb0 -> bb2;
  bb2 -> bb3;
  bb3 -> bb4 [label="true", color=green];
  bb3 -> bb2 [label="false", color=red];
  bb4 -> bb1;
}
